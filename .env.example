# Web push (generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Supabase (Project Settings → API). The secret key is server-only —
# a legacy service_role key also works here.
SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Shared secret between the GitHub Actions cron and /api/notify/run.
# Set the same value as a repo Actions secret, along with APP_URL.
CRON_SECRET=
